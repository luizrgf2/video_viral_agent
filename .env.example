# Audio Transcription Configuration
# Options: local, groq
AUDIO_TRANSCRIPTION_MODE=local

# Groq API Configuration (required if AUDIO_TRANSCRIPTION_MODE=groq)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API Configuration (required for LLM analysis)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model Configuration
VLM_MODEL_NAME=anthropic/claude-3.5-sonnet
LLM_MODEL_NAME=openai/gpt-4o

# Groq Whisper Model Options (if using Groq)
# whisper-large-v3-turbo (recommended) - Faster, good accuracy
# whisper-large-v3 - Most accurate, slower
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Flask Configuration
SITE_URL=http://localhost:8000
APP_NAME=Video Viral Agent
LOG_LEVEL=INFO
